<Window 
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" x:Class="PDownloader.Tray.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PDownloader.Tray.Views"
        xmlns:tray="http://schemas.lepo.co/wpfui/2022/xaml/tray"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:MainWindow,
                                 IsDesignTimeCreatable=True}"
        Title="PDownloader Tray"
        Width="0" Height="0"
        ShowInTaskbar="False"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        Visibility="Hidden">
    <Grid>
        <tray:NotifyIcon
            x:Name="TrayIcon"
            FocusOnLeftClick="False"
            Icon="pack://application:,,,/Assets/app-100.png"
            MenuOnRightClick="True"
            LeftClick="NotifyIcon_LeftClick"
            TooltipText="{Binding ViewModel.ApplicationTitle, Mode=OneWay}">
            <tray:NotifyIcon.Menu>
                <ContextMenu 
                    ItemsSource="{Binding ViewModel.TrayMenuItems, Mode=OneWay}" />
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>
    </Grid>
</Window>
