<Page
    x:Class="PDownloader.Views.Pages.DownloadsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PDownloader.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:utils="clr-namespace:PDownloader.Utils"
    xmlns:models="clr-namespace:PDownloader.Models"
    Title="DownloadsPage"
    d:DataContext="{d:DesignInstance local:DownloadsPage, IsDesignTimeCreatable=False}"
    d:DesignHeight="600" d:DesignWidth="900"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d"
    ScrollViewer.CanContentScroll="False">

    <Page.Resources>
        <!-- Progress bar track -->
        <Style x:Key="DownloadProgressBar" TargetType="ProgressBar">
            <Setter Property="Height"     Value="4"/>
            <Setter Property="Minimum"    Value="0"/>
            <Setter Property="Maximum"    Value="100"/>
            <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="Foreground" Value="#FF4FC3F7"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Top border ──────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Padding="1" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"/>

        <!-- ── List ───────────────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" ui:SmoothScrollBehavior.IsEnabled="True"
                      VerticalScrollBarVisibility="Auto" Padding="0,8">
            <StackPanel>

                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="0,80,0,0"
                            Visibility="{Binding ViewModel.IsEmpty, Converter={StaticResource BoolToVisConverter}}">
                    <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="64"
                                   Opacity="0.2" HorizontalAlignment="Center"/>
                    <TextBlock Text="{utils:Localization page_downloads_empty_title}"
                               Opacity="0.5" FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,16,0,0"/>
                    <TextBlock Text="{utils:Localization page_downloads_empty_hint}"
                               Opacity="0.35" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Download items -->
                <ItemsControl ItemsSource="{Binding ViewModel.Downloads}"
                              Visibility="{Binding ViewModel.IsEmpty,
                                           Converter={StaticResource BoolToVisConverter},
                                           ConverterParameter=invert}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:DownloadItemDto}">
                            <ui:Card Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="118" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Status icon -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Status, Converter={StaticResource StatusToIconConverter}}"
                                               FontSize="22" VerticalAlignment="Center"
                                               Margin="0,0,14,0"
                                               Foreground="{Binding Status, Mode=OneWay,
                                                            Converter={StaticResource StatusToColorConverter}}"/>

                                    <!-- File info -->
                                    <StackPanel Grid.Column="1"
                                                Margin="0 0 10 0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FileName}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                        <TextBlock Text="{Binding Url}"
                                                   FontSize="11"
                                                   Opacity="0.45"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,2,0,6" />
                                        <ProgressBar Style="{StaticResource DownloadProgressBar}"
                                                     Value="{Binding Progress, Mode=OneWay}"
                                                     Margin="0,0,0,4" />
                                        <TextBlock FontSize="11"
                                                   Opacity="0.6">
                                            <Run Text="{Binding DownloadedFormatted, Mode=OneWay}" />
                                            <Run Text=" / " />
                                            <Run Text="{Binding TotalFormatted, Mode=OneWay}" />
                                            <Run Text="  " />
                                            <Run Foreground="{Binding Status, Mode=OneWay, Converter={StaticResource StatusToColorConverter}}">
                                                <Run.Text>
                                                    <MultiBinding Converter="{StaticResource StatusToTextConverter}"
                                                                  Mode="OneWay">
                                                        <Binding Path="Status" />
                                                        <Binding Path="ErrorMessage" />
                                                    </MultiBinding>
                                                </Run.Text>
                                            </Run>
                                        </TextBlock>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                        <!-- Progress % -->
                                        <Grid HorizontalAlignment="Stretch">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <!-- Speed + ETA -->
                                            <StackPanel Grid.Column="0"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding SpeedFormatted, Mode=OneWay}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                                <TextBlock Text="{Binding EtaFormatted, Mode=OneWay}"
                                                           FontSize="11"
                                                           Opacity="0.5"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="1"
                                                       VerticalAlignment="Top"
                                                       HorizontalAlignment="Right"
                                                       FontSize="13"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding Status, Mode=OneWay,
                                                                Converter={StaticResource StatusToColorConverter}}">
                                                <Run Text="{Binding Progress, Mode=OneWay, StringFormat={}{0:F0}%}" />
                                            </TextBlock>
                                        </Grid>

                                        <!-- Action buttons -->
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Margin="0 5 0 0">
                                            <ui:Button Icon="{ui:SymbolIcon Pause24}"
                                                       Margin="0 0 2 0"
                                                       ToolTip="{utils:Localization page_downloads_pause}"
                                                       Command="{Binding DataContext.ViewModel.PauseCommand,
                                                             RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                       CommandParameter="{Binding}"
                                                       Visibility="{Binding IsActive, Converter={StaticResource BoolToVisConverter}}" />

                                            <ui:Button Icon="{ui:SymbolIcon Play24}"
                                                       Margin="0 0 2 0"
                                                       ToolTip="{utils:Localization page_downloads_resume}"
                                                       Command="{Binding DataContext.ViewModel.ResumeCommand,
                                                             RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                       CommandParameter="{Binding}">
                                                <ui:Button.Visibility>
                                                    <Binding Path="IsActive"
                                                             Converter="{StaticResource BoolToVisConverter}">
                                                        <Binding.ConverterParameter>invert</Binding.ConverterParameter>
                                                    </Binding>
                                                </ui:Button.Visibility>
                                            </ui:Button>

                                            <ui:Button Icon="{ui:SymbolIcon ArrowCounterclockwise24}"
                                                       ToolTip="{utils:Localization page_downloads_retry}"
                                                       Margin="0 0 2 0"
                                                       Command="{Binding DataContext.ViewModel.RetryCommand,
                                                             RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                       CommandParameter="{Binding}">
                                                <ui:Button.Visibility>
                                                    <Binding Path="Status"
                                                             Converter="{StaticResource BoolToVisConverter}"
                                                             ConverterParameter="Error" />
                                                </ui:Button.Visibility>
                                            </ui:Button>

                                            <ui:Button Icon="{ui:SymbolIcon FolderOpen24}"
                                                       ToolTip="{utils:Localization page_downloads_open_folder}"
                                                       Margin="0 0 2 0"
                                                       Command="{Binding DataContext.ViewModel.OpenFolderCommand,
                                                             RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                       CommandParameter="{Binding}" />

                                            <ui:Button Icon="{ui:SymbolIcon Delete24}"
                                                       ToolTip="{utils:Localization page_downloads_cancel}"
                                                       Foreground="#AAEF5350"
                                                       Command="{Binding DataContext.ViewModel.CancelCommand,
                                                             RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                       CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </ui:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <!-- ── Status bar ──────────────────────────────────────────────────── -->
        <Border Grid.Row="2" Padding="24,8" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding ViewModel.StatusText}"
                           Opacity="0.5" FontSize="12" VerticalAlignment="Center"/>
                <ui:Button Grid.Column="1"
                           Content="{utils:Localization page_downloads_refresh}"
                           Icon="{ui:SymbolIcon ArrowClockwise24}"
                           Appearance="Transparent"
                           Command="{Binding ViewModel.RefreshCommand}"/>
            </Grid>
        </Border>
    </Grid>
</Page>
