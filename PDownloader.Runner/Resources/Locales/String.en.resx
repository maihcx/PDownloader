<?xml version="1.0" encoding="utf-8"?>
<root>
  <xsd:schema id="root" xmlns="" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:msdata="urn:schemas-microsoft-com:xml-msdata">
    <xsd:element name="root" msdata:IsDataSet="true">
      <xsd:complexType>
        <xsd:choice maxOccurs="unbounded">
          <xsd:element name="data">
            <xsd:complexType>
              <xsd:sequence>
                <xsd:element name="value" type="xsd:string" minOccurs="0" msdata:Ordinal="1"/>
              </xsd:sequence>
              <xsd:attribute name="name" type="xsd:string"/>
            </xsd:complexType>
          </xsd:element>
        </xsd:choice>
      </xsd:complexType>
    </xsd:element>
  </xsd:schema>
  <resheader name="resmimetype"><value>text/microsoft-resx</value></resheader>
  <resheader name="version"><value>2.0</value></resheader>
  <resheader name="reader"><value>System.Resources.ResXResourceReader</value></resheader>
  <resheader name="writer"><value>System.Resources.ResXResourceWriter</value></resheader>

  <data name="AppTitle"            xml:space="preserve"><value>PDownloader</value></data>
  <data name="NewDownload"         xml:space="preserve"><value>New Download</value></data>
  <data name="Pause"               xml:space="preserve"><value>Pause</value></data>
  <data name="Resume"              xml:space="preserve"><value>Resume</value></data>
  <data name="Cancel"              xml:space="preserve"><value>Cancel</value></data>
  <data name="Retry"               xml:space="preserve"><value>Retry</value></data>
  <data name="OpenFile"            xml:space="preserve"><value>Open File</value></data>
  <data name="OpenFolder"          xml:space="preserve"><value>Open Folder</value></data>
  <data name="PauseAll"            xml:space="preserve"><value>Pause All</value></data>
  <data name="ResumeAll"           xml:space="preserve"><value>Resume All</value></data>
  <data name="StatusReady"         xml:space="preserve"><value>Ready</value></data>
  <data name="StatusDownloading"   xml:space="preserve"><value>Downloading</value></data>
  <data name="StatusPaused"        xml:space="preserve"><value>Paused</value></data>
  <data name="StatusCompleted"     xml:space="preserve"><value>Completed</value></data>
  <data name="StatusError"         xml:space="preserve"><value>Error</value></data>
  <data name="StatusMerging"       xml:space="preserve"><value>Merging segments...</value></data>
  <data name="StatusConnecting"    xml:space="preserve"><value>Connecting...</value></data>
  <data name="ConfirmCancel"       xml:space="preserve"><value>Are you sure you want to cancel this download?</value></data>
  <data name="UrlLabel"            xml:space="preserve"><value>Download URL</value></data>
  <data name="FileNameLabel"       xml:space="preserve"><value>File name (optional)</value></data>
  <data name="SaveToLabel"         xml:space="preserve"><value>Save to folder</value></data>
  <data name="ThreadsLabel"        xml:space="preserve"><value>Download threads</value></data>
  <data name="EmptyStateTitle"     xml:space="preserve"><value>No downloads yet</value></data>
  <data name="EmptyStateHint"      xml:space="preserve"><value>Click '+ New Download' or install the browser extension to get started</value></data>
</root>
