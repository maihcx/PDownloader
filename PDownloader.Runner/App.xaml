<Application x:Class="PDownloader.Runner.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             DispatcherUnhandledException="OnDispatcherUnhandledException"
             xmlns:helpers="clr-namespace:PDownloader.Runner.Helpers"
             Exit="OnExit"
             Startup="OnStartup">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <helpers:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter" />
            <helpers:ProgressToWidthConverter  x:Key="ProgressToWidthConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
