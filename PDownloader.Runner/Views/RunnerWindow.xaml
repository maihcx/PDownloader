<Window x:Class="PDownloader.Runner.Views.RunnerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:converter="clr-namespace:PDownloader.Runner.Helpers"
        xmlns:local="clr-namespace:PDownloader.Runner.Views"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:RunnerWindow, IsDesignTimeCreatable=False}"
        Title="PDownloader — Xác nhận tải xuống"
        Width="520"
        Height="Auto"
        SizeToContent="Height"
        MinWidth="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="True">

    <Window.Resources>
        <converter:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converter:EnumToVisibilityConverter x:Key="IsForm" />
        <converter:EnumToVisibilityConverter x:Key="IsDownloading" />
        <converter:EnumToVisibilityConverter x:Key="IsCompleted" />
        <converter:ProgressToWidthConverter  x:Key="ProgressToWidth" />

        <Style x:Key="InputBox"
               TargetType="TextBox">
            <Setter Property="Background"
                    Value="#FF0D1117" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="CaretBrush"
                    Value="White" />
            <Setter Property="BorderBrush"
                    Value="#33FFFFFF" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Setter Property="Padding"
                    Value="10,8" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused"
                                     Value="True">
                                <Setter Property="BorderBrush"
                                        Value="#4FC3F7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FlatBtn"
               TargetType="Button">
            <Setter Property="Background"
                    Value="#22FFFFFF" />
            <Setter Property="Foreground"
                    Value="#CCFFFFFF" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="16,9" />
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="FontSize"
                    Value="13" />
            <Setter Property="FontWeight"
                    Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="#33FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="bd"
                                        Property="Background"
                                        Value="#44FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentBtn"
               TargetType="Button"
               BasedOn="{StaticResource FlatBtn}">
            <Setter Property="Background"
                    Value="#FF4FC3F7" />
            <Setter Property="Foreground"
                    Value="#FF0D1117" />
        </Style>
    </Window.Resources>

    <!-- Drop shadow wrapper -->
    <Border Margin="12"
            CornerRadius="14"
            Background="#FF141820"
            BorderBrush="#22FFFFFF"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28"
                              ShadowDepth="0"
                              Color="Black"
                              Opacity="0.7" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <!-- title bar -->
                <RowDefinition Height="Auto" />
                <!-- file info -->
                <RowDefinition Height="Auto" />
                <!-- fields -->
                <RowDefinition Height="Auto" />
                <!-- actions -->
            </Grid.RowDefinitions>

            <!-- ── Title bar ───────────────────────────────────────────────── -->
            <Border Grid.Row="0"
                    Background="#FF0D1117"
                    CornerRadius="14,14,0,0"
                    Padding="18,12"
                    MouseLeftButtonDown="OnTitleBarDrag">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="⬇"
                               FontSize="16"
                               Foreground="#FF4FC3F7"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0" />
                    <TextBlock Grid.Column="1"
                               Text="PDownloader — Tải xuống mới"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="2"
                            Content="✕"
                            Style="{StaticResource FlatBtn}"
                            Padding="8,4"
                            Foreground="#88FFFFFF"
                            Click="OnClose" />
                </Grid>
            </Border>

            <!-- ── File info card ──────────────────────────────────────────── -->
            <Border Grid.Row="1"
                    Background="#0AFFFFFF"
                    Margin="16,16,16,0"
                    CornerRadius="10"
                    Padding="14,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="📄"
                               FontSize="28"
                               VerticalAlignment="Center"
                               Margin="0,0,14,0" />
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding ViewModel.FileName}"
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding ViewModel.Url}"
                                   Foreground="#66FFFFFF"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="2"
                        Margin="16,14,16,0"
                        Visibility="{Binding ViewModel.State,
                         Converter={StaticResource IsForm},
                         ConverterParameter=Form}">

                <TextBlock Text="Tên file"
                           Foreground="#88FFFFFF"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5" />
                <TextBox Style="{StaticResource InputBox}"
                         Text="{Binding ViewModel.FileName, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" />

                <TextBlock Text="Lưu vào thư mục"
                           Foreground="#88FFFFFF"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5" />
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Style="{StaticResource InputBox}"
                             Text="{Binding ViewModel.SaveTo, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Content="…"
                            Style="{StaticResource FlatBtn}"
                            Margin="6,0,0,0"
                            Padding="12,8"
                            Command="{Binding ViewModel.BrowseFolderCommand}" />
                </Grid>

                <TextBlock Text="Số luồng tải"
                           Foreground="#88FFFFFF"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5" />
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,4">
                    <Slider Minimum="1"
                            Maximum="32"
                            Value="{Binding ViewModel.Threads}"
                            Width="200"
                            VerticalAlignment="Center" />
                    <TextBlock Text="{Binding ViewModel.Threads}"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="12,0,4,0" />
                    <TextBlock Text="luồng"
                               Foreground="#55FFFFFF"
                               FontSize="12"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>

            <!-- ── Progress panel ─────────────────────────── -->
            <StackPanel Grid.Row="2"
                        Margin="16,14,16,0"
                        Visibility="{Binding ViewModel.State,
                         Converter={StaticResource IsDownloading},
                         ConverterParameter=Downloading}">

                <!-- Status text -->
                <TextBlock Text="{Binding ViewModel.StatusText}"
                           Foreground="#88FFFFFF"
                           FontSize="11"
                           Margin="0,0,0,8" />

                <!-- Progress bar -->
                <!-- Thay toàn bộ Grid progress bar cũ bằng đoạn này -->
                <Grid Margin="0,0,0,6"
                      Height="10">
                    <!-- Track -->
                    <Border Background="#1AFFFFFF"
                            CornerRadius="4" />
                    <!-- Fill — scale theo X từ trái -->
                    <Border CornerRadius="4"
                            HorizontalAlignment="Left"
                            Width="{Binding ActualWidth,
                RelativeSource={RelativeSource AncestorType=Grid}}">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="ProgressScale"
                                            ScaleX="{Binding ViewModel.ProgressRatio}"
                                            CenterX="0" />
                        </Border.RenderTransform>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0"
                                                 EndPoint="1,0">
                                <GradientStop Color="#FF2a5adf"
                                              Offset="0" />
                                <GradientStop Color="#FF4FC3F7"
                                              Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>

                <!-- Percent + stats row -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding ViewModel.ProgressText}"
                               Foreground="#FF4FC3F7"
                               FontSize="13"
                               FontWeight="Bold" />
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal">
                        <TextBlock Text="{Binding ViewModel.DownloadedText}"
                                   Foreground="#88FFFFFF"
                                   FontSize="11" />
                        <TextBlock Text=" / "
                                   Foreground="#44FFFFFF"
                                   FontSize="11" />
                        <TextBlock Text="{Binding ViewModel.TotalText}"
                                   Foreground="#88FFFFFF"
                                   FontSize="11" />
                    </StackPanel>
                </Grid>

                <!-- Speed + ETA -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal">
                        <TextBlock Text="↓ "
                                   Foreground="#FF4FC3F7"
                                   FontSize="12" />
                        <TextBlock Text="{Binding ViewModel.SpeedText}"
                                   Foreground="White"
                                   FontSize="12" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <TextBlock Text="ETA: "
                                   Foreground="#55FFFFFF"
                                   FontSize="12" />
                        <TextBlock Text="{Binding ViewModel.EtaText}"
                                   Foreground="White"
                                   FontSize="12" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- ── Actions (Form) ─────────────────────────── -->
            <Border Grid.Row="3"
                    Padding="16,14,16,16"
                    Visibility="{Binding ViewModel.State,
                     Converter={StaticResource IsForm},
                     ConverterParameter=Form}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding ViewModel.ErrorText}"
                               Foreground="#FFEF5350"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Visibility="{Binding ViewModel.HasError, Converter={StaticResource BoolToVis}}" />
                    <Button Grid.Column="1"
                            Content="Hủy"
                            Style="{StaticResource FlatBtn}"
                            Margin="0,0,8,0"
                            Click="OnClose" />
                    <Button Grid.Column="2"
                            Content="⬇  Bắt đầu tải"
                            Style="{StaticResource AccentBtn}"
                            Command="{Binding ViewModel.ConfirmDownloadCommand}" />
                </Grid>
            </Border>

            <!-- ── Actions (Downloading) ─────────────────── -->
            <Border Grid.Row="3"
                    Padding="16,10,16,16"
                    Visibility="{Binding ViewModel.State,
                         Converter={StaticResource IsDownloading},
                         ConverterParameter=Downloading}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!-- Sending indicator -->
                    <TextBlock Grid.Column="0"
                               Text="Đang gửi lệnh…"
                               Foreground="#55FFFFFF"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Visibility="{Binding ViewModel.IsSending, Converter={StaticResource BoolToVis}}" />

                    <Button Grid.Column="1"
                            Style="{StaticResource FlatBtn}"
                            Margin="0,0,8,0"
                            Command="{Binding ViewModel.PauseResumeCommand}">
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text"
                                            Value="⏸  Tạm dừng" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ViewModel.IsPaused}"
                                                     Value="True">
                                            <Setter Property="Text"
                                                    Value="▶  Tiếp tục" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                    <Button Grid.Column="2"
                            Content="✕  Hủy"
                            Style="{StaticResource FlatBtn}"
                            Foreground="#FFEF5350"
                            Command="{Binding ViewModel.CancelDownloadCommand}" />
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Padding="16,14,16,16"
                    Visibility="{Binding ViewModel.State,
                     Converter={StaticResource IsCompleted},
                     ConverterParameter=Completed}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Tên file đã xong -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="✅ "
                                   FontSize="13" />
                        <TextBlock Text="Tải xuống hoàn tất"
                                   Foreground="#FF4CAF50"
                                   FontSize="12"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="📂  Mở thư mục"
                            Style="{StaticResource FlatBtn}"
                            Margin="0,0,8,0"
                            Command="{Binding ViewModel.OpenFolderCommand}" />

                    <Button Grid.Column="2"
                            Content="▶  Mở"
                            Style="{StaticResource AccentBtn}"
                            Command="{Binding ViewModel.OpenFileCommand}" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
