<Page x:Class="PDownloader.Runner.Views.DownloaderProgressPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PDownloader.Runner.Views"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:utils="clr-namespace:PDownloader.Runner.Utils"
      mc:Ignorable="d"
      d:DataContext="{d:DesignInstance local:DownloaderProgressPage,
                               IsDesignTimeCreatable=False}"
      d:DesignHeight="400"
      d:DesignWidth="800"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Title="DownloaderPage"
      ScrollViewer.CanContentScroll="False">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      ui:SmoothScrollBehavior.IsEnabled="True"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <ui:CardAction IsChevronVisible="False">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="📄"
                                   FontSize="28"
                                   VerticalAlignment="Center"
                                   Margin="0,0,14,0" />
                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding ViewModel.RunnerConfig.FileName}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding ViewModel.RunnerConfig.InitialUrl}"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,3,0,0" />
                        </StackPanel>
                    </Grid>
                </ui:CardAction>

                <StackPanel Grid.Row="2"
                            Margin="0 8 0 0">

                    <!-- Status text -->
                    <TextBlock Text="{Binding ViewModel.StatusText}"
                               FontSize="11"
                               Margin="0,0,0,0" />

                    <!-- Progress bar -->
                    <ProgressBar Margin="0 4 0 0"
                                 Value="{Binding ViewModel.ProgressPercent, Mode=OneWay}"
                                 Maximum="100" />

                    <!-- Percent + stats row -->
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding ViewModel.ProgressText}"
                                   FontSize="13"
                                   FontWeight="Bold" />
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal">
                            <TextBlock Text="{Binding ViewModel.DownloadedText}"
                                       FontSize="11" />
                            <TextBlock Text=" / "
                                       FontSize="11" />
                            <TextBlock Text="{Binding ViewModel.TotalText}"
                                       FontSize="11" />
                        </StackPanel>
                    </Grid>

                    <!-- Speed + ETA -->
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal">
                            <TextBlock Text="↓ "
                                       FontSize="12" />
                            <TextBlock Text="{Binding ViewModel.SpeedText}"
                                       FontSize="12" />
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <TextBlock Text="ETA: "
                                       FontSize="12" />
                            <TextBlock Text="{Binding ViewModel.EtaText}"
                                       FontSize="12" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Margin="0 8 0 0">
            <Border Visibility="{Binding ViewModel.DownloaderStatus.State,
                    Converter={StaticResource EnumToVisibilityConverter},
                    ConverterParameter=Downloading}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0"
                               Text="{utils:Localization sending_command_title}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Visibility="{Binding ViewModel.DownloaderStatus.IsSending, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <ui:Button Grid.Column="1"
                               Margin="0,0,8,0"
                               Content="{utils:Localization pause_title}"
                               Command="{Binding ViewModel.PauseCommand}"
                               Visibility="{Binding ViewModel.DownloaderStatus.IsPaused, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=invert}"
                               IsEnabled="{Binding ViewModel.IsActionButtonEnabled, Mode=OneWay}">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Pause16" />
                        </ui:Button.Icon>
                    </ui:Button>

                    <ui:Button Grid.Column="1"
                               Margin="0,0,8,0"
                               Content="{utils:Localization resume_title}"
                               Command="{Binding ViewModel.ResumeCommand}"
                               Visibility="{Binding ViewModel.DownloaderStatus.IsPaused, Converter={StaticResource BoolToVisibilityConverter}}"
                               IsEnabled="{Binding ViewModel.IsActionButtonEnabled, Mode=OneWay}">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Play16" />
                        </ui:Button.Icon>
                    </ui:Button>

                    <ui:Button Grid.Column="2"
                               Content="{utils:Localization cancel_title}"
                               Appearance="Danger"
                               Command="{Binding ViewModel.CancelDownloadCommand}"
                               IsEnabled="{Binding ViewModel.IsActionButtonEnabled, Mode=OneWay}">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Stop16" />
                        </ui:Button.Icon>
                    </ui:Button>
                </Grid>
            </Border>

            <Border Visibility="{Binding ViewModel.DownloaderStatus.State,
                    Converter={StaticResource EnumToVisibilityConverter},
                    ConverterParameter=Completed}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="CheckboxChecked16"
                                       Foreground="{DynamicResource SystemFillColorSuccessBrush}" />
                        <TextBlock Text="{utils:Localization status_completed_title}"
                                   Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="3 0 0 0" />
                    </StackPanel>

                    <ui:Button Grid.Column="1"
                               Content="{utils:Localization open_folder_title}"
                               Margin="0,0,8,0"
                               Command="{Binding ViewModel.OpenFolderCommand}">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="FolderOpen16" />
                        </ui:Button.Icon>
                    </ui:Button>

                    <ui:Button Grid.Column="2"
                               Appearance="Primary"
                               Content="{utils:Localization open_file_title}"
                               Command="{Binding ViewModel.OpenFileCommand}">
                        <ui:Button.Icon>
                            <ui:SymbolIcon Symbol="Open16" />
                        </ui:Button.Icon>
                    </ui:Button>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</Page>
